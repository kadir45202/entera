# =====================================================================
# Entera — root .gitignore
# =====================================================================

# ---------- Secrets / Environment ----------
.env
.env.*
!.env.example
!.env.*.example
*.local
secrets.*
serviceAccount*.json
*.pem
*.p12
*.key

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- IDE / Editor ----------
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# =====================================================================
# Python / FastAPI  (backend/)
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
.cache
nosetests.xml
coverage.xml
*.cover

# Local databases
*.sqlite
*.sqlite3
*.db

# =====================================================================
# Flutter / Dart  (frontend/)
# =====================================================================
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/build/
.flutter-plugins
.flutter-plugins-dependencies

# Android
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/key.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.keystore
*.jks

# iOS
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Pods/
**/ios/.symlinks/

# macOS / Linux / Windows desktop (Flutter)
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/
**/macos/Pods/
**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/

# =====================================================================
# Node / JS (if any tooling)
# =====================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Logs / temp ----------
*.log
logs/
tmp/
temp/
