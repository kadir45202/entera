# Environment Configuration
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=entera
POSTGRES_PASSWORD=entera_secret
POSTGRES_DB=entera
DATABASE_URL=postgresql+asyncpg://entera:entera_secret@localhost:5432/entera

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Integration
GEMINI_API_KEY=your-gemini-api-key

# Development
DEBUG=true
